{
  "info": {
    "name": "vue3-element-admin API 测试",
    "description": "后台管理系统接口测试集合\n项目：vue3-element-admin\nMock 基地址：http://localhost:3002/dev-api/api/v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3002/dev-api/api/v1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. 认证模块",
      "item": [
        {
          "name": "获取验证码",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', () => pm.response.to.have.status(200));",
                  "pm.test('code=00000', () => pm.response.json().code === '00000');",
                  "pm.test('返回 captchaKey', () => pm.response.json().data.captchaKey !== '');",
                  "pm.test('返回 captchaBase64', () => pm.response.json().data.captchaBase64.startsWith('data:image'));",
                  "",
                  "// 保存 captchaKey 备用",
                  "pm.environment.set('captchaKey', pm.response.json().data.captchaKey);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/captcha"
          }
        },
        {
          "name": "登录 - 验证码正确",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', () => pm.response.to.have.status(200));",
                  "pm.test('code=00000', () => pm.response.json().code === '00000');",
                  "pm.test('msg=登录成功', () => pm.response.json().msg === '登录成功');",
                  "pm.test('返回 accessToken', () => pm.response.json().data.accessToken !== '');",
                  "",
                  "// 保存 token 供后续请求使用",
                  "const token = pm.response.json().data.accessToken;",
                  "pm.environment.set('token', 'Bearer ' + token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\",\n  \"captchaKey\": \"{{captchaKey}}\",\n  \"captchaCode\": \"0\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "登录 - 验证码错误",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', () => pm.response.to.have.status(200));",
                  "pm.test('code=B0001', () => pm.response.json().code === 'B0001');",
                  "pm.test('提示验证码错误', () => pm.response.json().msg.includes('验证码错误'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\",\n  \"captchaKey\": \"xxx\",\n  \"captchaCode\": \"999\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "登录 - 验证码为空",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', () => pm.response.to.have.status(200));",
                  "pm.test('code=B0001', () => pm.response.json().code === 'B0001');",
                  "pm.test('提示验证码不能为空', () => pm.response.json().msg.includes('验证码不能为空'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\",\n  \"captchaKey\": \"xxx\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "注销",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', () => pm.response.to.have.status(200));",
                  "pm.test('code=00000', () => pm.response.json().code === '00000');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "2. 用户管理",
      "item": [
        {
          "name": "获取用户列表",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', () => pm.response.to.have.status(200));",
                  "pm.test('code=00000', () => pm.response.json().code === '00000');",
                  "pm.test('返回列表数据', () => pm.response.json().data.list.length > 0);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/page?pageNum=1&pageSize=10",
              "host": ["{{base_url}}"],
              "path": ["users", "page"],
              "query": [
                { "key": "pageNum", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "新增用户",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码 200', () => pm.response.to.have.status(200));",
                  "pm.test('code=00000', () => pm.response.json().code === '00000');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"nickname\": \"测试用户\",\n  \"password\": \"123456\",\n  \"mobile\": \"13800138000\",\n  \"email\": \"test@example.com\",\n  \"status\": 1,\n  \"deptId\": 1,\n  \"roleIds\": [2]\n}"
            },
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "修改用户",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 2,\n  \"username\": \"admin\",\n  \"nickname\": \"管理员（已修改）\",\n  \"mobile\": \"13800138001\",\n  \"email\": \"admin@example.com\"\n}"
            },
            "url": "{{base_url}}/users/2"
          }
        },
        {
          "name": "删除用户",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/users/3"
          }
        },
        {
          "name": "重置用户密码",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"666666\"\n}"
            },
            "url": "{{base_url}}/users/2/password"
          }
        }
      ]
    },
